# =====================
# Django / Security
# =====================
DJANGO_SECRET_KEY=replace-me-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# =====================
# CORS (comma-separated)
# =====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =====================
# Database (optional)
# =====================
# Using SQLite by default in this project.
# To switch to Postgres, update job_portal/settings.py accordingly.

# =====================
# JWT / SimpleJWT
# =====================
# SIMPLE_JWT uses SIGNING_KEY=DJANGO_SECRET_KEY by default (see settings).
# Token lifetimes can be overridden in settings if needed.

